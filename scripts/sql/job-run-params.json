{
  "_comment": "写入作业 DataStreamperf_paimon 的真实平台运行参数（2026-07-07 核对）。这是真实提交形态的一部分：SQL body（01/02/03/05）+ 本运行参数 JSON。所有 execution.*/table.exec.*/parallelism.* 等在此配置，不在 SQL 里 SET。",
  "_notes": {
    "not-null-enforcer": "平台运行参数为 ERROR（权威）；旧 05 脚本里 SET 的是 DROP，已弃用，以此处 ERROR 为准。",
    "upsert-materialize": "旧 05 脚本另 SET 过 table.exec.sink.upsert-materialize=NONE；若需保留该优化，加到下面 jobRunningParams 即可（原始平台参数未包含）。",
    "parallelism_bucket": "parallelism.default=3 与表 bucket=3、Kafka 3 分区对齐。",
    "metrics": "metrics.reporter.kafka.filter.includes=* → 全量指标上报到 RDW_ODS_FLINK_METRICS，供 analysis-sql 使用。"
  },
  "taskName": "DataStreamperf_paimon",
  "taskVersion": "1",
  "sqlPath": "/user/flink_user/datastream/task/<task-uuid>",
  "mode": "STREAMING",
  "modelTablePath": "/user/flink_user/datastream/modeltable",
  "jobRunningParams": {
    "parallelism.default": "3",
    "taskmanager.numberOfTaskSlots": "1",
    "taskmanager.memory.process.size": "2GB",
    "taskmanager.memory.managed.fraction": "0.2",
    "jobmanager.memory.process.size": "1536MB",
    "yarn.containers.vcores": "2",
    "yarn.appmaster.vcores": "1",
    "state.backend.type": "rocksdb",
    "state.backend.incremental": "true",
    "state.checkpoints.num-retained": "10",
    "execution.checkpointing.mode": "EXACTLY_ONCE",
    "execution.checkpointing.interval": "3min",
    "execution.checkpointing.min-pause": "1min",
    "execution.checkpointing.timeout": "10min",
    "execution.checkpointing.tolerable-failed-checkpoints": "2",
    "execution.checkpointing.interval-during-backlog": "5min",
    "execution.checkpointing.externalized-checkpoint-retention": "RETAIN_ON_CANCELLATION",
    "restart-strategy.type": "fixed-delay",
    "restart-strategy.fixed-delay.attempts": "3",
    "restart-strategy.fixed-delay.delay": "10s",
    "pipeline.operator-chaining.enabled": "true",
    "taskmanager.network.memory.buffer-debloat.enabled": "true",
    "table.exec.sink.not-null-enforcer": "ERROR",
    "table.exec.source.idle-timeout": "1min",
    "table.exec.state.ttl": "24h",
    "table.exec.mini-batch.enabled": "true",
    "table.exec.mini-batch.size": "5000",
    "table.exec.mini-batch.allow-latency": "5s",
    "metrics.reporter.kafka.filter.includes": "*"
  }
}
